#!/bin/sh
set -eu

# Resolve symlinks to find the real script location.
# macOS readlink doesn't support -f, so we resolve manually.
resolve_dir() {
  local target="$1"
  while [ -L "$target" ]; do
    local dir=$(dirname -- "$target")
    target=$(readlink -- "$target")
    case "$target" in
      /*) ;;
      *) target="$dir/$target" ;;
    esac
  done
  dirname -- "$target"
}

SCRIPT_DIR="$(resolve_dir "$0")"

if command -v python3 >/dev/null 2>&1; then
  if python3 -c "import tomllib" 2>/dev/null || python3 -c "import tomli" 2>/dev/null; then
    exec python3 "$SCRIPT_DIR/../hub.py" "$@"
  fi
fi
if command -v python >/dev/null 2>&1; then
  exec python "$SCRIPT_DIR/../hub.py" "$@"
fi

echo "Error: python 3.9+ is required but not found" >&2
exit 1
