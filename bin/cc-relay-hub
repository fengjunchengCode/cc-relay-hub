#!/bin/sh
set -eu

# Resolve symlinks to find the real script location.
# macOS readlink doesn't support -f, so we resolve manually.
resolve_dir() {
  local target="$1"
  while [ -L "$target" ]; do
    local dir=$(dirname -- "$target")
    target=$(readlink -- "$target")
    case "$target" in
      /*) ;;
      *) target="$dir/$target" ;;
    esac
  done
  dirname -- "$target"
}

SCRIPT_DIR="$(resolve_dir "$0")"

run_if_usable() {
  candidate="$1"
  shift
  if command -v "$candidate" >/dev/null 2>&1; then
    if "$candidate" -c "import sys; assert sys.version_info >= (3, 9); import tomllib" 2>/dev/null || "$candidate" -c "import sys; assert sys.version_info >= (3, 9); import tomli" 2>/dev/null; then
      exec "$candidate" "$SCRIPT_DIR/../hub.py" "$@"
    fi
  fi
}

run_if_usable python3 "$@"
run_if_usable python "$@"

if command -v py >/dev/null 2>&1; then
  if py -3 -c "import sys; assert sys.version_info >= (3, 9); import tomllib" 2>/dev/null || py -3 -c "import sys; assert sys.version_info >= (3, 9); import tomli" 2>/dev/null; then
    exec py -3 "$SCRIPT_DIR/../hub.py" "$@"
  fi
fi

echo "Error: Python 3.9+ with tomllib or tomli is required but not found" >&2
exit 1
